# Yamtrack configuration for YunoHost
# This file is managed by YunoHost. Do not edit manually.

# Django
SECRET=__SECRET__
DEBUG=False
ALLOWED_HOSTS=__DOMAIN__
CSRF=https://__DOMAIN__
URLS=https://__DOMAIN__

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=__DB_NAME__
DB_USER=__DB_USER__
DB_PASSWORD=__DB_PWD__

# Redis
REDIS_URL=redis://localhost:6379/__REDIS_DB__

# Timezone
TZ=__TIMEZONE__

# Logout redirects to YunoHost SSO
ACCOUNT_LOGOUT_REDIRECT_URL=https://__DOMAIN__/yunohost/sso/?action=logout

# TLS CA bundle for outgoing HTTPS requests (e.g. OIDC/Dex discovery)
REQUESTS_CA_BUNDLE=__INSTALL_DIR__/certs/ca-bundle.crt

# SSO / OIDC settings are appended below by the install/upgrade script
